<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokenea Visual - <%= viewdata.pokenea.nombre %></title>
    <style>
        :root {
            --primary: #6366f1;
            --secondary: #3b82f6;
            --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            --card-bg: rgba(255, 255, 255, 0.8);
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: rgba(255, 255, 255, 1);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 90%;
            max-width: 480px;
            padding: 2.5rem;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 2px solid var(--border);
            border-radius: 32px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            text-align: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .container:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 30px -5px rgba(0, 0, 0, 0.1);
        }

        .pokenea-img {
            width: 280px;
            height: 280px;
            object-fit: contain;
            filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.1));
            margin-bottom: 1rem;
            animation: float 4s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        h1 {
            font-size: 2.8rem;
            margin: 0.5rem 0;
            background: linear-gradient(to right, #4f46e5, #0ea5e9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900;
            letter-spacing: -0.025em;
        }

        .frase-container {
            margin: 2rem 0;
            padding: 1.5rem;
            background: white;
            border-radius: 20px;
            box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05);
            font-style: italic;
            font-size: 1.25rem;
            line-height: 1.6;
            color: #334155;
            border-left: 6px solid var(--primary);
        }

        .footer {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e2e8f0;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .container-id {
            display: inline-block;
            margin-top: 0.6rem;
            padding: 0.4rem 1rem;
            background: #f1f5f9;
            color: var(--primary);
            border-radius: 12px;
            font-family: 'Fira Code', monospace;
            font-weight: 600;
            border: 1px solid #e2e8f0;
        }

        .refresh-btn {
            margin-top: 1.5rem;
            padding: 1rem 2rem;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 16px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s;
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
        }

        .refresh-btn:hover {
            background: #4f46e5;
            transform: scale(1.05);
            box-shadow: 0 20px 25px -5px rgba(99, 102, 241, 0.4);
        }
    </style>
</head>
<body>
    <div class="container">
        <img src="<%= viewdata.pokenea.imagen %>" alt="<%= viewdata.pokenea.nombre %>" class="pokenea-img">
        
        <h1><%= viewdata.pokenea.nombre %></h1>
        
        <div class="frase-container">
            "<%= viewdata.pokenea.frase %>"
        </div>

        <a href="/visual" class="refresh-btn">Ver otro Pokenea</a>

        <div class="footer">
            <div>Corriendo en el contenedor:</div>
            <div class="container-id"><%= viewdata.containerId %></div>
        </div>
    </div>
</body>
</html>
